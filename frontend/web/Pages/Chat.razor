@page "/chat"

@using AskMyDocs.Web.Services
@using AskMyDocs.Web.Models
@using Markdig
@using Microsoft.AspNetCore.Components
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components.Forms

@inject ApiService ApiService
@inject ILocalStorageService LocalStorage
@inject UploadService UploadService

<h3 class="mb-4">AskMyDocs AI</h3>

<div class="card mb-3 p-3">

    <h5>Upload PDF</h5>

    <InputFile OnChange="HandleFileUpload"
               accept=".pdf" />

    @if (IsUploading)
    {
        <p class="mt-2">
            Uploading and processing PDF...
        </p>
    }

    @if (!string.IsNullOrEmpty(
        UploadMessage))
    {
        <div class="alert alert-info mt-2">

            @UploadMessage

        </div>
    }

</div>

<div class="chat-container">

    @foreach (var message in Messages)
    {
        <div class="message-wrapper @(message.Role)">

            <div class="message-bubble @(message.Role)">

                @((MarkupString)Markdown.ToHtml(
                    message.Content))

            </div>

        </div>
    }

</div>

<div class="input-container">

    <input class="form-control"
           @bind="Question"
           @bind:event="oninput"
           placeholder="Ask something about your documents..." />

    <div class="mt-2">

        <button class="btn btn-primary"
                @onclick="SendQuestion"
                disabled="@IsLoading">

            @(IsLoading ? "Thinking..." : "Send")

        </button>

        <button class="btn btn-danger ms-2"
                @onclick="ClearChat">

            Clear Chat

        </button>

    </div>

</div>

@code {

    private string Question = "";

    private bool IsLoading = false;

    private List<ChatMessage> Messages = new();

    private bool IsUploading = false;

    private string UploadMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var savedMessages =
            await LocalStorage.GetItemAsync
            <List<ChatMessage>>(
                "chat_history");

        if (savedMessages != null)
        {
            Messages = savedMessages;
        }
    }

    private async Task SaveChat()
    {
        await LocalStorage.SetItemAsync(
            "chat_history",
            Messages);
    }

    private async Task ClearChat()
    {
        Messages.Clear();

        await LocalStorage.RemoveItemAsync(
            "chat_history");

        StateHasChanged();
    }

    private async Task SendQuestion()
    {
        if (string.IsNullOrWhiteSpace(Question))
            return;

        IsLoading = true;

        // Add user message
        Messages.Add(new ChatMessage
        {
            Role = "user",
            Content = Question
        });

        await SaveChat();

        // Create empty AI message
        var aiMessage = new ChatMessage
        {
            Role = "assistant",
            Content = ""
        };

        Messages.Add(aiMessage);

        var currentQuestion = Question;

        Question = "";

        StateHasChanged();

        // Stream AI response
        await ApiService.StreamQuestion(
            currentQuestion,
            Messages,
            async chunk =>
            {
                aiMessage.Content += chunk;

                await SaveChat();

                await InvokeAsync(
                    StateHasChanged);
            });

        IsLoading = false;
    }

    private async Task HandleFileUpload(
    InputFileChangeEventArgs e)
    {
        try
        {
            IsUploading = true;

            UploadMessage = "";

            var file = e.File;

            var success =
                await UploadService
                    .UploadPdf(file);

            if (success)
            {
                UploadMessage =
                    "PDF uploaded successfully!";
            }
            else
            {
                UploadMessage =
                    "Upload failed.";
            }
        }
        catch (Exception ex)
        {
            UploadMessage =
                $"Error: {ex.Message}";
        }
        finally
        {
            IsUploading = false;
        }
    }
}